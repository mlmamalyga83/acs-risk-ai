# ============================================================
# ACS ECG Detector — переменные окружения
# ============================================================
# Скопируйте этот файл: cp .env.example .env
# Заполните реальными значениями.

# JWT Secret (для веб-интерфейса, опционально)
JWT_SECRET=change-me-to-random-string

# Database (для веб-интерфейса, опционально)
DATABASE_URL=postgresql://user:pass@localhost:5432/ecg_detector
REDIS_URL=redis://localhost:6379/0

# Model paths
MODEL_PATH=models/best_encoder.pt
CONFIG_PATH=config/config.yaml
